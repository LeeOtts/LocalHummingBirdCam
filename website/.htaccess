ErrorDocument 404 /404.html

# Route site_data.json through PHP to bypass SiteGround dynamic cache
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^data/site_data\.json$ /data/site_data.php [L]
</IfModule>

# Prevent caching on data files so sprinkler/sleeping state updates promptly
<FilesMatch "site_data\.json$">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
        Header set Vary "*"
        Header set Surrogate-Control "no-store"
    </IfModule>
</FilesMatch>

# HLS streaming — MIME types for .m3u8 playlists and .ts segments
<IfModule mod_mime.c>
    AddType application/vnd.apple.mpegurl .m3u8
    AddType video/mp2t .ts
</IfModule>

# HLS playlists must never be cached (updated every few seconds)
<FilesMatch "\.m3u8$">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
        Header set Access-Control-Allow-Origin "*"
    </IfModule>
</FilesMatch>

# HLS segments are immutable once written — short cache is fine
<FilesMatch "\.ts$">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=60"
        Header set Access-Control-Allow-Origin "*"
    </IfModule>
</FilesMatch>

# HTML pages — revalidate every time (SiteGround caches aggressively)
<FilesMatch "\.html$">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-cache, must-revalidate"
    </IfModule>
</FilesMatch>

# Block dotfiles (protects config files etc.)
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>
