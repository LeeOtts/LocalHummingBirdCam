# OpenAI / Azure OpenAI API
# For direct OpenAI: just set OPENAI_API_KEY (starts with sk-)
# For Azure OpenAI: set all four values below
OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Facebook Graph API
FACEBOOK_PAGE_ID=your-page-id-here
FACEBOOK_PAGE_ACCESS_TOKEN=your-page-access-token-here
FACEBOOK_API_VERSION=v25.0

# Detection tuning
MOTION_THRESHOLD=15.0
COLOR_MIN_AREA=300
COLOR_MAX_AREA=5000
DETECTION_COOLDOWN_SECONDS=60
MAX_POSTS_PER_DAY=10

# Vision verification — local bird species classifier (no API needed)
# Uses MobileNetV2 trained on 964 bird species including hummingbirds
VISION_VERIFY_ENABLED=true

# Vision captions — send a frame to GPT-4o so captions describe what the bird is doing
VISION_CAPTION_ENABLED=true
VISION_CAPTION_DETAIL=low

# Camera: "usb" (default), "picamera", or "auto"
CAMERA_TYPE=usb
USB_CAMERA_INDEX=0
# Rotation: 0, 90, 180, 270 (for upside-down or sideways mounting)
CAMERA_ROTATION=0
# Focus: disable autofocus and set manual focus (0=far, 255=near)
# Useful if the camera focuses on the background instead of the feeder
CAMERA_AUTOFOCUS=true
CAMERA_FOCUS=0
# Keep auto-exposure on even with manual focus (prevents dark image)
CAMERA_AUTO_EXPOSURE=true

# Audio — captured from USB camera mic or separate USB mic
# Run "arecord -l" on the Pi to find your device
AUDIO_ENABLED=true
AUDIO_DEVICE=default

# Video settings
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=15
CLIP_PRE_SECONDS=5
CLIP_POST_SECONDS=20
VIDEO_BITRATE=5000000
MAX_CLIPS_DISK_MB=2000

# Paths
CLIPS_DIR=clips
LOGS_DIR=logs

# Test mode — set to false to enable Facebook posting
TEST_MODE=true

# Night mode — auto sleep/wake based on sunrise/sunset
# Change these to your location (lat/lng from Google Maps)
LOCATION_LAT=
LOCATION_LNG=-
LOCATION_TIMEZONE=America/Chicago
LOCATION_NAME=Bartlett, TN
WAKE_BEFORE_SUNRISE_MIN=30
SLEEP_AFTER_SUNSET_MIN=30
NIGHT_MODE_ENABLED=true

# Bluesky (AT Protocol) — leave blank to disable
# Create an app password at Settings > App Passwords on bsky.app
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Instagram — leave blank to disable
# Uses Facebook Page Access Token (ensure instagram_business_content_management scope)
# Find IDs in Meta Business Suite > Instagram > Settings
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_USER_ID=
INSTAGRAM_MAX_POSTS_PER_DAY=10

# Twitter/X — leave blank to disable
# Get keys at developer.twitter.com (free tier = 1,500 tweets/month)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# TikTok — leave blank to disable
# Register at developers.tiktok.com, then run: python scripts/tiktok_auth.py
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_MAX_POSTS_PER_DAY=10
TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE

# Weather (OpenWeatherMap free tier) — leave blank to disable
# Get a free API key at openweathermap.org
OPENWEATHERMAP_API_KEY=

# AI comment replies — auto-reply to Facebook comments with GPT-4o
AUTO_REPLY_ENABLED=false
AUTO_REPLY_MAX_PER_HOUR=5

# Weekly digest — auto-post a recap every week (day name, e.g. "sunday")
WEEKLY_DIGEST_ENABLED=true
WEEKLY_DIGEST_DAY=sunday


# Website sync
# rsync over SSH — run scripts/sync_to_site.sh (cron every 5 min on Pi)
WEBSITE_REMOTE_HOST=
WEBSITE_REMOTE_USER=
WEBSITE_REMOTE_PORT=
WEBSITE_REMOTE_PATH=

# B-Hyve sprinkler monitor & control — leave blank to disable
# Uses your Orbit/B-Hyve app login to monitor and control your sprinkler
BHYVE_EMAIL=
BHYVE_PASSWORD=
# Which station/zone to watch (1 = first zone in the app, 0 = any zone)
BHYVE_STATION=1
# Mister run time per watering (minutes) and safety cap
BHYVE_RUN_MINUTES=5
BHYVE_MAX_RUN_MINUTES=30
# Automated watering schedule — waters every N hours starting N hours after sunrise
BHYVE_SCHEDULE_ENABLED=true
BHYVE_SCHEDULE_OFFSET_HOURS=3
BHYVE_SCHEDULE_INTERVAL_HOURS=3

# Web dashboard
WEB_HOST=0.0.0.0
WEB_PORT=8080
# Optional: set a password to enable HTTP Basic Auth on the dashboard.
# Leave blank (default) to keep the dashboard open on your local network.
WEB_PASSWORD=

# Tailscale — remote access via Tailscale VPN (optional)
# Run: bash scripts/setup_tailscale.sh
# Set to true to show Tailscale status on the dashboard
TAILSCALE_ENABLED=false
