# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here

# Facebook Graph API
FACEBOOK_PAGE_ID=your-page-id-here
FACEBOOK_PAGE_ACCESS_TOKEN=your-page-access-token-here

# Detection tuning
MOTION_THRESHOLD=7.0
COLOR_MIN_AREA=200
DETECTION_COOLDOWN_SECONDS=60
MAX_POSTS_PER_DAY=10

# Camera: "auto" (try Pi Camera, fall back to USB), "picamera", or "usb"
CAMERA_TYPE=auto
USB_CAMERA_INDEX=0

# Video settings
VIDEO_WIDTH=640
VIDEO_HEIGHT=480
VIDEO_FPS=24
CLIP_PRE_SECONDS=10
CLIP_POST_SECONDS=20
VIDEO_BITRATE=1500000

# Paths
CLIPS_DIR=clips
LOGS_DIR=logs

# Web dashboard
WEB_HOST=0.0.0.0
WEB_PORT=8080
